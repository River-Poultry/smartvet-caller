NODE_ENV=production
PORT=4600

# PostgreSQL — use a managed instance (Neon, Supabase, Railway, etc.)
DATABASE_URL=postgresql://user:password@host:5432/smartvet_callcenter

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex
JWT_EXPIRES_IN=8h

# Twilio VoIP
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+256xxxxxxxxx
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SmartVet Core API (live Django backend)
SMARTVET_CORE_API=https://smartvet.africa
SMARTVET_CORE_API_KEY=

# External AI Model (leave blank to use built-in prescription engine)
AI_MODEL_URL=
AI_MODEL_KEY=

# URLs
APP_URL=https://your-api-domain.com
FRONTEND_URL=https://your-frontend-domain.com
